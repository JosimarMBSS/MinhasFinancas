<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="Minhas Finanças em versão Android nativa Java.

Inclui dashboard, lançamentos, categorias, recorrências e relatórios filtráveis.

Base preparada para evoluir para backup, exportação e release profissional."
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
</LinearLayout>
